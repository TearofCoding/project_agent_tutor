# ── MySQL ──────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=ai_tutor

# ── Spring DataSource ──────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/ai_tutor?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=aitutor
SPRING_DATASOURCE_PASSWORD=change_me_db

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_key_must_be_32chars
JWT_ACCESS_EXPIRY_MS=1800000
JWT_REFRESH_EXPIRY_MS=604800000

# ── Internal Service Auth ──────────────────────────────────────────────────────
INTERNAL_API_KEY=change_me_internal_key_must_be_32chars
FASTAPI_BASE_URL=http://fastapi:8000

# ── Anthropic / LLM (FastAPI container only) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-change_me
LLM_MODEL=claude-sonnet-4-6

# ── Email ──────────────────────────────────────────────────────────────────────
EMAIL_VERIFICATION_ENABLED=false
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@aitutor.local

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=change_me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=change_me_google_secret

# ── SkillOpt Thresholds (dev: 1/1/5 — prod: 5/3/30) ──────────────────────────
SKILLOPT_MIN_TOTAL_SESSIONS=1
SKILLOPT_MIN_NEW_SESSIONS=1
SKILLOPT_MAX_VALIDATION_SIZE=5
